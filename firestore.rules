rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    function isMerchant() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/merchants/$(request.auth.uid));
    }
    function isCustomer() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/customers/$(request.auth.uid));
    }
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function merchantIdOf(uid) {
      return get(/databases/$(database)/documents/merchants/$(uid)).data.merchant_id;
    }

    // ---------- admins/{uid} ----------
    // Admin registry. Bootstrap the first admin manually from Firebase Console.
    // After that, existing admins can promote/demote other users from the UI.
    match /admins/{uid} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ---------- customers/{uid} ----------
    match /customers/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      allow create: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.role == 'customer'
        && request.resource.data.account_number is string
        && request.resource.data.account_number.size() >= 10
        && request.resource.data.wallet_balance is number
        && request.resource.data.wallet_balance >= 0;

      // Owner may edit profile fields and wallet_balance.
      allow update: if isOwner(uid)
        && request.resource.data.account_number == resource.data.account_number
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role
        && request.resource.data.wallet_balance is number
        && request.resource.data.wallet_balance >= 0;

      // Admin may update any field (e.g., toggle is_verified).
      allow update: if isAdmin();

      allow delete: if isAdmin();
    }

    // ---------- merchants/{uid} ----------
    match /merchants/{uid} {
      allow read: if isSignedIn();

      allow create: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.role == 'merchant'
        && request.resource.data.merchant_id is string
        && request.resource.data.merchant_id.size() >= 4
        && request.resource.data.wallet_balance is number
        && request.resource.data.wallet_balance >= 0;

      allow update: if isOwner(uid)
        && request.resource.data.merchant_id == resource.data.merchant_id
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role
        && request.resource.data.wallet_balance is number
        && request.resource.data.wallet_balance >= 0;

      // Any signed-in user (paying customer) may credit merchant wallet by
      // strictly increasing wallet_balance during payment approval.
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['wallet_balance'])
        && request.resource.data.wallet_balance is number
        && request.resource.data.wallet_balance > resource.data.get('wallet_balance', 0);

      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ---------- account_numbers/{n} ----------
    match /account_numbers/{num} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ---------- merchant_ids/{id} ----------
    match /merchant_ids/{mid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ---------- meta/counters ----------
    match /meta/{docId} {
      allow read, write: if isSignedIn();
    }

    // ---------- transactions/{id} ----------
    match /transactions/{txId} {
      allow create: if isMerchant()
        && request.resource.data.merchant_uid == request.auth.uid
        && request.resource.data.merchant_id == merchantIdOf(request.auth.uid)
        && request.resource.data.account_number is string
        && request.resource.data.account_number.size() >= 10
        && request.resource.data.customer_uid is string
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.status == 'pending';

      allow read: if isAdmin()
        || (isSignedIn() && resource.data.merchant_uid == request.auth.uid)
        || (isSignedIn() && resource.data.customer_uid == request.auth.uid);

      allow update: if isAdmin()
        || (
          isSignedIn()
          && resource.data.customer_uid == request.auth.uid
          && resource.data.status == 'pending'
          && request.resource.data.status in ['completed','declined']
          && request.resource.data.account_number == resource.data.account_number
          && request.resource.data.customer_uid == resource.data.customer_uid
          && request.resource.data.merchant_uid == resource.data.merchant_uid
          && request.resource.data.merchant_id == resource.data.merchant_id
          && request.resource.data.amount == resource.data.amount
        );

      allow delete: if isAdmin();
    }

    // ---------- notifications/{id} ----------
    match /notifications/{id} {
      allow read: if isSignedIn() && resource.data.user_uid == request.auth.uid;
      // Any signed-in user may create a notification addressed to another user
      // (e.g. merchant → customer payment request, admin → user alerts).
      allow create: if isSignedIn()
        && request.resource.data.user_uid is string
        && request.resource.data.title is string
        && request.resource.data.body is string;
      allow update: if isSignedIn() && resource.data.user_uid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAdmin();
    }


    // ---------- settlements/{id} ----------
    match /settlements/{id} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.merchant_uid == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
