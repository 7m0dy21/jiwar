rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // Spark-plan compatible: role is determined by the existence of a
    // merchants/{uid} or customers/{uid} profile document. No Custom Claims,
    // no Cloud Functions required.
    function isMerchant() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/merchants/$(request.auth.uid));
    }
    function isCustomer() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/customers/$(request.auth.uid));
    }
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function merchantIdOf(uid) {
      return get(/databases/$(database)/documents/merchants/$(uid)).data.merchant_id;
    }

    // ---------- customers/{uid} ----------
    // Personal profile. Only the customer (or admin) can read.
    // Merchants have NO read access to customer profile data.
    match /customers/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      allow create: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.role == 'customer'
        && request.resource.data.account_number is string
        && request.resource.data.account_number.size() >= 10;

      // Customer may edit profile fields, never account_number, uid or role.
      allow update: if isOwner(uid)
        && request.resource.data.account_number == resource.data.account_number
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role;

      allow delete: if isAdmin();
    }

    // ---------- merchants/{uid} ----------
    // Store profile. Owner or admin full read; other authenticated users may
    // read to confirm a merchant exists (needed for scanning receipts and for
    // the transaction-create rule to look up merchant_id).
    match /merchants/{uid} {
      allow read: if isSignedIn();

      allow create: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.role == 'merchant'
        && request.resource.data.merchant_id is string
        && request.resource.data.merchant_id.size() >= 4;

      allow update: if isOwner(uid)
        && request.resource.data.merchant_id == resource.data.merchant_id
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role;

      allow delete: if isAdmin();
    }

    // ---------- account_numbers/{n} ----------
    // Reservation index enforcing uniqueness. Payload = {uid, createdAt} only.
    // Any signed-in user (including merchants) may read to resolve
    // account_number → uid for routing a transaction. No PII exposed.
    match /account_numbers/{num} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ---------- merchant_ids/{id} ----------
    match /merchant_ids/{mid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ---------- meta/counters ----------
    match /meta/{docId} {
      allow read, write: if isSignedIn();
    }

    // ---------- transactions/{id} ----------
    // Merchants MAY create transactions, but ONLY for their own merchant_id.
    // Role is determined by the presence of a merchants/{uid} profile doc.
    // Merchants cannot read customers/{uid}; the transaction record carries
    // only the account_number and customer_uid needed for the transaction.
    match /transactions/{txId} {
      allow create: if isMerchant()
        && request.resource.data.merchant_uid == request.auth.uid
        && request.resource.data.merchant_id == merchantIdOf(request.auth.uid)
        && request.resource.data.account_number is string
        && request.resource.data.account_number.size() >= 10
        && request.resource.data.customer_uid is string
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.status == 'pending';

      allow read: if isAdmin()
        || (isSignedIn() && resource.data.merchant_uid == request.auth.uid)
        || (isSignedIn() && resource.data.customer_uid == request.auth.uid);

      // Only the target customer can approve/decline their own pending tx.
      allow update: if isAdmin()
        || (
          isSignedIn()
          && resource.data.customer_uid == request.auth.uid
          && resource.data.status == 'pending'
          && request.resource.data.status in ['completed','declined']
          && request.resource.data.account_number == resource.data.account_number
          && request.resource.data.customer_uid == resource.data.customer_uid
          && request.resource.data.merchant_uid == resource.data.merchant_uid
          && request.resource.data.merchant_id == resource.data.merchant_id
          && request.resource.data.amount == resource.data.amount
        );

      allow delete: if isAdmin();
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
